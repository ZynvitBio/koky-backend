{
  "kind": "collectionType",
  "collectionName": "recipes",
  "info": {
    "singularName": "recipe",
    "pluralName": "recipes",
    "displayName": "Recipe"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "shortDescription": {
      "type": "text"
    },
    "preparationTimeMinutes": {
      "type": "integer"
    },
    "servings": {
      "type": "integer"
    },
    "mainImage": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "published": {
      "type": "boolean",
      "default": true
    },
    "videoUrl": {
      "type": "string"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "recipes"
    },
    "bannerImage": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "videoThumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "ingredients": {
      "type": "component",
      "component": "recipe-elements.ingredients",
      "repeatable": true
    },
    "instructions": {
      "type": "component",
      "component": "recipe-elements.instruction-step",
      "repeatable": true
    },
    "cookingTip": {
      "type": "text"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "recipes"
    },
    "position": {
      "type": "enumeration",
      "enum": [
        "left",
        "right"
      ]
    }
  }
}
